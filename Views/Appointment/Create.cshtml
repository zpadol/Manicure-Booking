@model ManicureBooking.Models.Appointment

@{
    ViewData["Title"] = "Stwórz";
}

<h1>Zaplanuj wizytę</h1>
<h4>Podaj dane:</h4>
<hr />
<div class="row justify-content-center">
    <div class="col-md-8 mx-auto">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ClientName" class="control-label"></label>
                <input asp-for="ClientName" class="form-control" />
                <span asp-validation-for="ClientName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ClientEmail" class="control-label"></label>
                <input asp-for="ClientEmail" class="form-control" />
                <span asp-validation-for="ClientEmail" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ClientPhone" class="control-label"></label>
                <input asp-for="ClientPhone" class="form-control" />
                <span asp-validation-for="ClientPhone" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AppointmentTime" class="control-label"></label>
                <input asp-for="AppointmentTime" class="form-control" />
                <span asp-validation-for="AppointmentTime" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ServiceId" class="control-label"></label>
                <select asp-for="ServiceId" class ="form-control" asp-items="ViewBag.ServiceId"></select>
            </div>
            <div id="serviceDetailsCard" class="card mb-3 border-primary" style="display: none;">
                <div class="card-body row">
                    <div class="col-md-5 d-flex align-items-center justify-content-center" id="serviceImageContainer">
                    </div>
                    <div class="col-md-7">
                        <h5 class="card-title"><strong>Szczegóły wybranej usługi</strong></h5>
                        <p class="card-text" id="serviceDesc"></p>
                        <hr />
                        <p class="card-text">
                            <strong>Cena:</strong> <span id="servicePrice"></span> zł
                        </p>
                        <p class="card-text">
                            <strong>Czas trwania:</strong> <span id="serviceDuration"></span> min
                        </p>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Utwórz" class="btn-hover color-10 w-100" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">← Powrót do listy</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const serviceSelect = document.getElementById('ServiceId');
        const detailsCard = document.getElementById('serviceDetailsCard');

        function fetchServiceDetails() {
            const id = serviceSelect.value;

            if (!id) {
                detailsCard.style.display = 'none';
                return;
            }
            fetch('/Service/GetServiceDetails/' + id)
                .then(response => response.json())
                .then(data => {
                    document.getElementById('serviceDesc').innerText = data.description;
                    document.getElementById('servicePrice').innerText = data.price.toFixed(2); 
                    document.getElementById('serviceDuration').innerText = data.duration;

                    const imgContainer = document.getElementById('serviceImageContainer');
                    if (data.imagePath) {
                       imgContainer.innerHTML = `<img src="/images/${data.imagePath}" class="img-fluid shadow" alt="Zdjęcie usługi" style="width: 100%; height: 250px; object-fit: cover; border-radius: 12px;" />`;
                    } else {
                        imgContainer.innerHTML = '<span class="text-muted small">Brak zdjęcia</span>';
                    }
                    detailsCard.style.display = 'flex';
                })
                .catch(error => console.error('Błąd pobierania danych:', error));
        }
        serviceSelect.addEventListener('change', fetchServiceDetails);
        fetchServiceDetails();
    </script>
}
